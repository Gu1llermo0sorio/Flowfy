{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/exchange-rates",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/recurring",
      "schedule": "0 3 * * *"
    }
  ]
}
